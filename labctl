#!/usr/bin/env bash
# labctl - Top-level control surface for the offensive-security lab.
#
# This is a thin dispatcher.  Each subcommand maps to a function below
# or to a script under scripts/.  Compose file stacking, profile
# selection, and environment wiring happen here so that the operator
# never has to remember the underlying compose incantations.
#
# Usage:  labctl <command> [flags]
# Help:   labctl help
set -euo pipefail

# ── Resolve paths ──────────────────────────────────────────────────
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
export LAB_ROOT="${LAB_ROOT:-/opt/lab}"
export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-lab}"

# ── Shared libraries ──────────────────────────────────────────────
source "${REPO_DIR}/scripts/lib/compose.sh"
source "${REPO_DIR}/scripts/lib/ui.sh"

# ── Subcommands ────────────────────────────────────────────────────

cmd_up() {
    # Pre-flight: catch the two most common first-run failures early.
    if [[ ! -d "$LAB_ROOT" ]]; then
        ui_error_block \
            "${LAB_ROOT} does not exist" \
            "Runtime data root is required before the lab can start" \
            "Host has not been provisioned yet" \
            "sudo labctl bootstrap"
        return 1
    fi
    if [[ ! -f "${REPO_DIR}/.env" ]]; then
        ui_error_block \
            ".env file not found in ${REPO_DIR}" \
            "Compose needs .env for volume paths and feature flags" \
            "Bootstrap did not complete or .env was deleted" \
            "cp .env.example .env   (then edit as needed)"
        return 1
    fi

    local profiles=()
    local hostnet_requested=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --gpu)      export LAB_GPU=1;      shift ;;
            --hostnet)  export LAB_HOSTNET=1; hostnet_requested=1; shift ;;
            --builder)  profiles+=(--profile build); shift ;;
            *)
                ui_fail "Unknown flag: $1"
                ui_note "Run 'labctl help up' for valid flags."
                return 1 ;;
        esac
    done
    if [[ "$hostnet_requested" == "1" ]]; then
        ui_warn "Host networking enabled (--hostnet)"
        ui_note "Containers share the host network namespace."
        ui_note "Use only when VPN/tun0 access from inside the container is required."
    fi
    if ! _compose "${profiles[@]}" up -d; then
        ui_error_block \
            "Compose failed to start the lab" \
            "Containers could not be created or started" \
            "Docker may not be running" \
            "systemctl status docker && labctl verify"
        return 1
    fi
    ui_pass "Lab is running"
    ui_next_block "labctl shell" "labctl launch default"
}

cmd_down() {
    if ! _compose down "$@"; then
        ui_error_block \
            "Compose down failed" \
            "Containers could not be stopped" \
            "Docker may not be running" \
            "systemctl status docker"
        return 1
    fi
    ui_pass "Lab stopped.  Data in ${LAB_ROOT} is intact."
    ui_next_block "labctl up" "labctl status"
}

cmd_build() {
    local extra=()
    [[ "${1:-}" == "--no-cache" ]] && extra=(--no-cache)
    if ! _compose build "${extra[@]}"; then
        ui_error_block \
            "Image build failed" \
            "Container images must build before the lab can start" \
            "See the Docker output above for the failing layer" \
            "labctl rebuild   (clean build, no cache)"
        return 1
    fi
    ui_pass "Images built"
    ui_next_block "labctl up"
}

cmd_rebuild() {
    if ! _compose build --no-cache; then
        ui_error_block \
            "Rebuild failed" \
            "Container images must build before the lab can start" \
            "See the Docker output above for the failing layer" \
            "Check docker/kali-main/Dockerfile"
        return 1
    fi
    ui_pass "Rebuilt from scratch"
    ui_next_block "labctl up"
}

cmd_shell() {
    local target="${1:-kali-main}"
    if ! _compose exec "$target" /bin/bash 2>/dev/null; then
        echo "" >&2
        ui_fail "Cannot open shell in '${target}'"
        ui_note "Why: the operator shell is the primary way to interact with the lab."
        # Distinguish between "not running" and "doesn't exist".
        if _compose ps --status running 2>/dev/null | grep -q "$target"; then
            ui_note "Cause: container exists but exec failed."
            ui_fix "labctl logs ${target}"
        else
            ui_note "Cause: container is not running."
            ui_fix "labctl up"
        fi
        return 1
    fi
}

cmd_logs() {
    if [[ -n "${1:-}" ]]; then
        _compose logs -f "$1"
    else
        _compose logs -f
    fi
}

cmd_sync() {
    bash "$REPO_DIR/scripts/sync-binaries.sh" "$@"
}

cmd_launch() {
    bash "$REPO_DIR/scripts/launch-lab.sh" "$@"
}

cmd_tmux() {
    local profile="${1:-}"
    if [[ -z "$profile" ]]; then
        echo "Available tmux profiles:"
        echo "  default     General operator session"
        echo "  htb         HTB/CTF workspace session"
        echo "  build       Build/tooling sidecar workflow"
        echo "  research    Research/notes workflow"
        return 0
    fi
    local script="$REPO_DIR/tmux/profiles/${profile}.sh"
    if [[ ! -f "$script" ]]; then
        ui_fail "No such profile: $profile"
        ui_note "Run 'labctl tmux' to list available profiles."
        return 1
    fi
    bash "$script"
}

cmd_workspace() {
    bash "$REPO_DIR/scripts/create-workspace.sh" "$@"
}

cmd_status() {
    # ── Collect state (fast, all read-only) ────────────────────────
    local kali_state="stopped" builder_state="stopped" kali_up=false

    # Container states via compose ps (handles both plugin and standalone).
    local ps_out
    if ps_out="$(_compose ps --format '{{.Name}} {{.State}}' 2>/dev/null)"; then
        while read -r cname cstate; do
            case "$cname" in
                lab-kali|*kali-main*) kali_state="$cstate"; [[ "$cstate" == "running" ]] && kali_up=true ;;
                lab-builder|*builder*) builder_state="$cstate" ;;
            esac
        done <<< "$ps_out"
    fi

    # Network mode.
    local net_mode="bridge"
    [[ "${LAB_HOSTNET:-0}" == "1" ]] && net_mode="host"

    # GPU.
    local gpu_mode="off"
    [[ "${LAB_GPU:-0}" == "1" ]] && gpu_mode="on"
    local gpu_hw=""
    if command -v nvidia-smi &>/dev/null; then
        gpu_hw="$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1)" || true
    fi

    # VPN.
    local vpn="disconnected"
    local vpn_ip=""
    if ip addr show tun0 &>/dev/null 2>&1; then
        vpn="connected"
        vpn_ip="$(ip -4 addr show tun0 2>/dev/null | awk '/inet/{print $2; exit}')"
    fi

    # Lab root.
    local lab_provisioned=false disk_usage="" ws_count=0 bin_count=0
    if [[ -d "$LAB_ROOT" ]]; then
        lab_provisioned=true
        disk_usage="$(du -sh "$LAB_ROOT" 2>/dev/null | awk '{print $1}')"
        ws_count="$(find "$LAB_ROOT/workspaces" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)"
        bin_count="$(find "$LAB_ROOT/tools/binaries" -type f 2>/dev/null | wc -l)"
    fi

    # Active tmux sessions inside the container.
    local tmux_sessions=""
    if $kali_up; then
        tmux_sessions="$(_compose exec -T kali-main tmux list-sessions -F '#{session_name}' 2>/dev/null | paste -sd ', ')" || true
    fi

    # ── Render ─────────────────────────────────────────────────────
    ui_banner "Hecate" "Status"

    ui_section "Lab"

    if $kali_up; then
        ui_kv "State" "running"
    else
        ui_kv "State" "stopped"
    fi

    # Containers.
    local _kali_mark="FAIL" _builder_mark="FAIL"
    [[ "$kali_state" == "running" ]] && _kali_mark="PASS"
    [[ "$builder_state" == "running" ]] && _builder_mark="PASS"

    ui_kv "kali-main" "$kali_state"
    if [[ "$builder_state" != "stopped" ]] || \
       _compose ps --format '{{.Name}}' 2>/dev/null | grep -q builder; then
        ui_kv "builder" "$builder_state"
    fi

    ui_section "Network & overlays"

    local net_detail="$net_mode"
    [[ "$net_mode" == "host" ]] && net_detail="host  (VPN/tun0 accessible inside container)"
    ui_kv "Network" "$net_detail"

    local gpu_detail="$gpu_mode"
    if [[ "$gpu_mode" == "on" && -n "$gpu_hw" ]]; then
        gpu_detail="on  ($gpu_hw)"
    elif [[ "$gpu_mode" == "off" && -n "$gpu_hw" ]]; then
        gpu_detail="off  (available — labctl up --gpu)"
    fi
    ui_kv "GPU" "$gpu_detail"

    local vpn_detail="$vpn"
    [[ -n "$vpn_ip" ]] && vpn_detail="$vpn  $vpn_ip"
    ui_kv "VPN" "$vpn_detail"

    ui_section "Storage"

    if $lab_provisioned; then
        ui_kv "LAB_ROOT" "${LAB_ROOT}  (${disk_usage:-?})"
        ui_kv "Workspaces" "$ws_count"
        if [[ "$bin_count" -gt 0 ]]; then
            ui_kv "Binaries" "${bin_count} files synced"
        else
            ui_kv "Binaries" "none  (labctl sync)"
        fi
    else
        ui_kv "LAB_ROOT" "${LAB_ROOT}  [not provisioned]"
        ui_fix "sudo labctl bootstrap"
    fi

    # tmux sessions.
    if [[ -n "$tmux_sessions" ]]; then
        echo ""
        ui_kv "tmux" "$tmux_sessions"
    fi

    # Quick actions.
    if $kali_up; then
        ui_next_block "labctl shell" "labctl launch <profile>"
    else
        ui_next_block "labctl up" "labctl build" "labctl verify"
    fi
}

cmd_bootstrap() {
    if [[ "$(id -u)" -ne 0 ]]; then
        ui_fail "Requires root"
        ui_fix "sudo labctl bootstrap"
        return 1
    fi
    bash "$REPO_DIR/scripts/bootstrap-host.sh"
}

cmd_verify() {
    bash "$REPO_DIR/scripts/verify-host.sh" "$@"
}

cmd_update() {
    bash "$REPO_DIR/scripts/update-lab.sh" "$@"
}

cmd_clean() {
    ui_warn "This removes Compose-managed containers and named volumes,"
    ui_note "and prunes dangling Docker images."
    ui_note "${LAB_ROOT} bind-mounted runtime data is NOT removed."
    ui_note "Note: any future named volumes added to Compose would also be removed."
    read -rp "    Proceed? [y/N] " ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
        _compose down -v --remove-orphans
        docker image prune -f
        ui_pass "Cleaned.  Bind-mounted data in ${LAB_ROOT} is intact."
        ui_next_block "labctl build" "labctl up"
    else
        ui_info "Aborted."
    fi
}

cmd_guide() {
    bash "$REPO_DIR/scripts/guide.sh" "$@"
}

cmd_version() {
    local sha="unknown" branch="unknown" date="unknown"
    if [[ -d "${REPO_DIR}/.git" ]]; then
        sha="$(git -C "$REPO_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
        branch="$(git -C "$REPO_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")"
        date="$(git -C "$REPO_DIR" log -1 --format=%cd --date=short 2>/dev/null || echo "unknown")"
    fi
    echo "labctl (hecate-bootstrap)  ${branch}@${sha}  ${date}"
}

# ── Help system ────────────────────────────────────────────────────

cmd_help() {
    local topic="${1:-}"

    # Dispatch to per-command help if a topic was given.
    if [[ -n "$topic" ]]; then
        local fn="cmd_help_${topic}"
        if declare -f "$fn" &>/dev/null; then
            "$fn"
            return
        fi
        ui_fail "No help entry for '${topic}'"
        ui_note "Run 'labctl help' for all commands."
        return 1
    fi

    cat <<'HELP'
labctl — Control surface for the Hecate offensive-security lab.

  Manages a Dockerized operator workstation built on Kali Rolling.
  Containers run your tools; persistent data lives on the host at
  /opt/lab and survives rebuilds.  labctl is the single entry point
  for setup, daily operation, and maintenance.

GETTING STARTED (first-time setup)
  New here?  Run 'labctl guide' for a step-by-step interactive walkthrough.

  Or follow these commands manually, in order, on a fresh Ubuntu 24.04 host:

    sudo labctl bootstrap       1. Install dependencies, create /opt/lab, seed config
    labctl verify               2. Confirm the host is ready (safe, read-only)
    labctl build                3. Build the kali-main container image
    labctl up                   4. Start the lab
    labctl launch default       5. Enter kali-main with a tmux operator session

  After step 1, log out and back in so the docker group takes effect.

DAILY WORKFLOW
  labctl up                     Start the lab (if not already running)
  labctl launch <profile>       Start containers + enter kali-main via tmux
  labctl shell                  Quick bash shell inside kali-main
  labctl status                 Check what is running, VPN, GPU, disk
  labctl down                   Stop the lab when done

  Launch profiles — each sets up a tmux layout suited to the task:
    default                     General-purpose session (main + ops windows)
    htb <target>                HTB engagement — creates a workspace for <target>
    build [name]                Compilation — starts the builder sidecar container
    research [topic]            Research / learning session

  Run 'labctl help launch' for detail.

COMMANDS
  Lifecycle        What it does
  ─────────────    ──────────────────────────────────────────────────
  up               Start containers         [--gpu] [--hostnet] [--builder]
  down             Stop and remove containers
  build            Build container images    [--no-cache]
  rebuild          Build from scratch (no Docker cache)
  clean            Remove containers, volumes, and prune images

  Interaction
  ─────────────    ──────────────────────────────────────────────────
  shell            Bash into a container     [container]  (default: kali-main)
  logs             Follow container logs     [container]  (default: all)

  Tooling
  ─────────────    ──────────────────────────────────────────────────
  sync             Download pinned binaries  [-n NAME] [--dry-run]
  tmux             Launch a tmux profile inside the container

  Workflow
  ─────────────    ──────────────────────────────────────────────────
  launch           Full launch — workspace + containers + tmux session
  workspace        Create an engagement workspace      [--profile P]

  Operations
  ─────────────    ──────────────────────────────────────────────────
  guide            Interactive setup walkthrough   [--explain]
  status           Lab health — containers, VPN, GPU, disk
  verify           Pre-flight host checks (read-only, always safe)
  update           Platform update           [--pull] [--empusa] [--binaries] …
  bootstrap        One-time host provisioning (requires sudo)
  version          Print labctl version info
  help [command]   This message, or help for a specific command

EXAMPLES
  First-time setup (run once, then log out and back in after step 1):
    sudo labctl bootstrap             Provision host, create /opt/lab, seed config
    labctl build                      Build the kali-main container image
    labctl up                         Start the lab
    labctl launch default             Enter kali-main with a tmux session

  HTB engagement against "resolute":
    labctl launch htb resolute        Create workspace + tmux session htb-resolute

  Research a vulnerability:
    labctl launch research cve-2024-1234
                                      Workspace + tmux session research-cve-2024-1234

  Build a custom tool with the builder sidecar:
    labctl launch build internal-webapp
                                      Workspace + builder container + tmux

  Enter a running lab:
    labctl shell                      Quick bash shell in kali-main
    labctl shell builder              Shell into the builder sidecar

  GPU passthrough + host-network VPN access:
    labctl up --gpu --hostnet         Both overlays in one command

  Sync binaries and update the platform:
    labctl sync --dry-run             Preview binary downloads
    labctl update --pull --empusa     Pull repo + update Empusa engine

  Create a workspace without launching:
    labctl workspace resolute --profile htb

TROUBLESHOOTING
  labctl verify                      Run first — catches most setup issues
  labctl status                      Is the lab actually running?
  labctl logs kali-main              Check container logs for errors
  labctl build --no-cache            Force a clean image rebuild
  labctl clean                       Nuclear option — wipe containers + volumes

  More detail: docs/troubleshooting.md

ENVIRONMENT
  LAB_ROOT       /opt/lab             Persistent data root (tools, workspaces, etc.)
  LAB_GPU=1                           Enable NVIDIA GPU passthrough (hashcat, etc.)
  LAB_HOSTNET=1                       Use host networking (direct VPN/tun0 access)

  Run 'labctl help up' or 'labctl help launch' for flag details.
HELP
}

# ── Per-command help ───────────────────────────────────────────────

cmd_help_up() {
    cat <<'HELP'
labctl up [--gpu] [--hostnet] [--builder]

  Start the lab containers in the background.

  --gpu        Enable NVIDIA GPU passthrough.  Requires nvidia-container-toolkit
               on the host.  Used for hashcat, GPU-accelerated tasks.
  --hostnet    Use host networking instead of Docker bridge.  Gives containers
               direct access to host interfaces including tun0 (VPN).
  --builder    Also start the builder sidecar — a headless Ubuntu container
               for cross-compilation.  Shares /opt/lab/tools with kali-main.

  Flags can be combined:  labctl up --gpu --hostnet --builder

  After 'up', enter the lab with:
    labctl shell          Quick bash shell
    labctl launch default Full tmux session

  Examples:
    labctl up                           Start kali-main in bridge mode
    labctl up --gpu                     Enable GPU passthrough for hashcat
    labctl up --hostnet                 Host networking — direct tun0/VPN access
    labctl up --gpu --hostnet --builder All overlays + builder sidecar
HELP
}

cmd_help_down() {
    cat <<'HELP'
labctl down

  Stop and remove lab containers.  Data in /opt/lab is not affected.
  Equivalent to: docker compose down

  Examples:
    labctl down                         Stop kali-main (and builder if running)
HELP
}

cmd_help_build() {
    cat <<'HELP'
labctl build [--no-cache]

  Build the kali-main (and builder) container images from the Dockerfiles
  in docker/.

  --no-cache    Ignore Docker layer cache — rebuild every layer from scratch.
                Use when a base image update or apt-package change is not
                being picked up.

  Shortcut:  labctl rebuild   (always uses --no-cache)

  After building:  labctl up

  Examples:
    labctl build                        Build all images (uses Docker cache)
    labctl build --no-cache             Full rebuild from scratch
    labctl rebuild                      Alias for build --no-cache
HELP
}

cmd_help_launch() {
    cat <<'HELP'
labctl launch <profile> [target]

  The full-stack launch command.  In one step it:
    1. Creates a workspace directory (if the profile takes a target/topic)
    2. Starts the compose stack (labctl up)
    3. Enters the kali-main container with a tmux session

  What is a workspace?
    A directory under /opt/lab/workspaces/<name> that holds your notes,
    scans, loot, and logs for one engagement or project.  Everything in
    it persists on the host and survives container rebuilds.

  What is tmux?
    A terminal multiplexer — think of it as tabs + split panes inside
    the container.  Each profile creates a pre-configured layout.
    Detach any time with Ctrl-b d.  Reattach by running the same
    launch command again.

  Profiles:
    default              General-purpose session.  No workspace created.
                         tmux session: lab        windows: main, ops

    htb <target>         Offensive engagement against <target>.
                         Creates /opt/lab/workspaces/<target>.
                         tmux session: htb-<target>  windows: main, ops
                         Both windows start in the workspace directory.

    build [name]         Compilation / tooling.  Starts the builder sidecar
                         (headless Ubuntu) alongside kali-main for cross-
                         compilation.  Optional workspace.
                         tmux session: build[-<name>]  windows: build, tools

    research [topic]     Research / study session.  Optional workspace.
                         tmux session: research[-<topic>]  windows: research, notes

  Re-entry:
    Running the same launch command again reattaches to the existing tmux
    session.  The workspace is not modified.  No session naming collisions —
    each target/topic gets its own tmux session.

  Examples:
    labctl launch default               General-purpose session, no workspace
    labctl launch htb resolute          HTB engagement for "resolute"
    labctl launch build internal-webapp Build workspace + builder sidecar
    labctl launch research cve-2024-1234
                                        Research session for a CVE

  When Empusa is installed, workspaces get full profile-specific layouts
  and template seeding.  Without Empusa, a minimal directory scaffold
  (notes/, scans/, loot/, logs/) is created instead.
HELP
}

cmd_help_workspace() {
    cat <<'HELP'
labctl workspace <name> [--profile <profile>]

  Create an engagement workspace directory under /opt/lab/workspaces/.

  Profiles: htb (default), build, research, internal

  With Empusa installed, the workspace receives profile-specific
  subdirectories, seeded templates, metadata, and lifecycle events.
  Without Empusa, a minimal scaffold is created: notes/, scans/,
  loot/, logs/.

  Running without a name lists existing workspaces.

  Examples:
    labctl workspace                    List existing workspaces
    labctl workspace resolute           Create workspace (default htb profile)
    labctl workspace internal-webapp --profile build
                                        Create a build-profiled workspace
HELP
}

