cmd_help_verify() {
    cat <<'HELP'
labctl verify

  Run pre-flight checks on the host.  Validates:
    - Ubuntu version                    - Required host commands
    - Docker daemon + Compose plugin    - /opt/lab directory tree
    - Repository files                  - Empusa installation
    - Binary sync state                 - GPU runtime (if LAB_GPU=1)

  Read-only — this never modifies the system.  Safe to run at any time.
  Returns exit code 1 if any critical check fails.

  Run this after bootstrap, before first launch, and when diagnosing
  any issue.  It catches most problems before they surface as cryptic
  Docker errors.

  Example:
    labctl verify                   Standard checks
    LAB_GPU=1 labctl verify         Also verify GPU passthrough
HELP
}

cmd_help_update() {
    cat <<'HELP'
labctl update [flags]

  Safely update the lab platform.  Runs host verification first, then
  optionally pulls the repo, updates Empusa, syncs binaries, rebuilds
  images, and restarts containers.  /opt/lab is never modified.

  On build failure, running containers are left intact — you can keep
  working while you diagnose.

  Flags:
    --pull        git pull the hecate-bootstrap repo
    --empusa      Update the Empusa workspace engine
    --binaries    Re-sync external binaries from manifests/binaries.tsv
    --no-build    Skip the image rebuild step
    --no-restart  Skip the compose restart after building
    --builder     Include the builder sidecar in the restart
    --gpu         Pass LAB_GPU=1 to compose operations
    --hostnet     Pass LAB_HOSTNET=1 to compose operations
    --force       Skip confirmation prompts

  Common patterns:
    labctl update --pull --empusa --binaries   Full update
    labctl update --pull --force               Pull + rebuild, no prompts
    labctl update --no-build --empusa          Update Empusa only
HELP
}

cmd_help_bootstrap() {
    cat <<'HELP'
labctl bootstrap

  One-time host provisioning.  Must be run as root (sudo labctl bootstrap).

  Performs 8 steps:
    1. Install host apt packages from manifests/apt-host.txt
    2. Install Docker Engine + Compose plugin
    3. Add current user to the docker group
    4. Install NVIDIA Container Toolkit (if GPU detected)
    5. Create /opt/lab directory tree
    6. Seed .env from .env.example
    7. Install Empusa workspace engine
    8. Symlink labctl to /usr/local/bin/

  After bootstrap, log out and back in for the docker group to take
  effect, then:
    labctl verify
    labctl build
    labctl up
HELP
}

cmd_help_clean() {
    cat <<'HELP'
labctl clean

  Interactive cleanup.  Removes Compose-managed containers and named
  volumes for this project, then prunes dangling Docker images.

  Bind-mounted runtime data under /opt/lab is NOT removed — your
  workspaces, tools, binaries, and saved data are safe.

  Note: any future named volumes added to Compose would also be removed
  by this command.  Today the project uses bind mounts only, but this is
  worth knowing if compose volumes are ever introduced.

  You will be prompted before anything is deleted.

  Examples:
    labctl clean                        Interactive cleanup (asks before deleting)
    labctl clean && labctl rebuild      Full reset — clean slate + fresh images
HELP
}

cmd_help_version() {
    cat <<'HELP'
labctl version

  Print the current labctl version: git branch, short commit SHA, and
  commit date.  Useful for bug reports and verifying which checkout is
  deployed.
HELP
}

cmd_help_guide() {
    cat <<'HELP'
labctl guide [--explain]

  Interactive setup walkthrough for first-time operators.

  Walks through 7 steps — verify, bootstrap, docker group, sync,
  build, up, and entering the lab — one at a time.  Each step is
  explained before anything runs.  Nothing is executed without
  your confirmation.

  --explain    Read-only reference mode.  Prints every step's
               explanation without prompts or execution.  Useful
               for reading ahead or sharing the setup guide.

  The guide detects what is already done (e.g. Docker installed,
  images built, containers running) and notes it at each step,
  so re-running after a partial setup picks up where you left off.

  Examples:
    labctl guide              Walk through setup interactively
    labctl guide --explain    Print the full guide as a reference
HELP
}

# ── Dispatch ───────────────────────────────────────────────────────
main() {
    local cmd="${1:-help}"
    shift || true
    case "$cmd" in
        up|down|build|rebuild|shell|logs|sync|tmux|launch|workspace|status|verify|update|bootstrap|clean|help|version|guide)
            "cmd_$cmd" "$@" ;;
        -h|--help)
            cmd_help "$@" ;;
        -v|--version)
            cmd_version ;;
        *)
            ui_fail "Unknown command: $cmd"
            ui_note "Run 'labctl help' for available commands."
            return 1 ;;
    esac
}

main "$@"
