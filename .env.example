# hecate-bootstrap environment — copy to .env and customise.
# .env is gitignored.  Never commit secrets.

# ── Paths ──────────────────────────────────────────────────────────

# Host root for persistent lab data (tools, workspaces, resources).
# Type: absolute path.  Default: /opt/lab.
# Used by: bootstrap-host.sh, create-workspace.sh, launch-lab.sh,
#          install-empusa.sh, sync-binaries.sh, verify-host.sh.
LAB_ROOT=/opt/lab

# ── Compose / Runtime ─────────────────────────────────────────────

# Docker Compose project name prefix for all lab containers.
# Type: string.  Default: lab.
# Used by: launch-lab.sh, lib/compose.sh.
COMPOSE_PROJECT_NAME=lab

# Stack the GPU passthrough compose overlay.
# Type: 0|1.  Default: 0.
# Used by: launch-lab.sh, update-lab.sh, lib/compose.sh.
LAB_GPU=0

# Stack the host-network compose overlay.
# Type: 0|1.  Default: 0.
# Used by: launch-lab.sh, update-lab.sh, lib/compose.sh.
LAB_HOSTNET=0

# ── Empusa Integration ────────────────────────────────────────────

# Git clone URL for the Empusa workspace engine.
# Type: URL.  Default: https://github.com/Icarus4122/empusa.git.
# Used by: install-empusa.sh.
EMPUSA_REPO=https://github.com/Icarus4122/empusa.git

# ── API Tokens ─────────────────────────────────────────────────────

# GitHub personal access token — raises API rate limit (60 → 5 000 req/hr).
# Type: string (PAT).  Default: unset (anonymous access).
# Used by: sync-binaries.sh.
# GITHUB_TOKEN=ghp_xxx
